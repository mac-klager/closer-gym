# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...
# Optional overrides:
# ANTHROPIC_MODEL=claude-opus-4-8
# PORT=3000

# Optional: natural prospect voices in voice mode (https://elevenlabs.io)
# Without this, voice mode falls back to your browser's built-in voices.
# ELEVENLABS_API_KEY=...
# ELEVENLABS_MODEL=eleven_flash_v2_5   (default — lowest latency; eleven_turbo_v2_5 = slightly higher quality, slower)
